# ===================================
# Application
# ===================================
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===================================
# Database
# ===================================
POSTGRES_USER=fai_user
POSTGRES_PASSWORD=fai_secret
POSTGRES_DB=football_ai
DATABASE_URL=postgresql+asyncpg://fai_user:fai_secret@localhost:5432/football_ai

# ===================================
# Redis
# ===================================
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ===================================
# Frontend
# ===================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ===================================
# CORS
# ===================================
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ===================================
# External APIs (optional)
# ===================================
FOOTBALL_DATA_API_KEY=your-football-data-org-api-key
ODDS_API_KEY=your-the-odds-api-key
RAPIDAPI_KEY=your-rapidapi-key

# ===================================
# Email (optional)
# ===================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@football-ai.com
EMAILS_FROM_NAME=Football AI Platform

# ===================================
# Stripe (optional)
# ===================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_VIP_PRICE_ID=price_...
